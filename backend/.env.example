# For Neon DB, ensure you use postgresql+asyncpg and append ?ssl=require
DATABASE_URL=postgresql+asyncpg://[username]:[password]@[endpoint_id].neon.tech/[db_name]?ssl=require
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:3000"]
RESEND_API_KEY=re_xxxx
ENVIRONMENT=development
